map $http_upgrade $connection_upgrade_{{ mail_host | regex_replace('[^A-Za-z0-9_]', '_') }} {
    default upgrade;
    '' close;
}

server {
    listen 80;
    listen [::]:80;
    server_name {{ mail_host }};

    client_max_body_size {{ nginx_client_max_body_size }};

{% if enable_mail_tools | bool %}
    location {{ tools_base_path }}/ {
        proxy_pass http://127.0.0.1:{{ tools_port }}{{ tools_base_path }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 300;
        proxy_send_timeout 300;
    }
{% endif %}

{% if enable_stalwart_admin_proxy | bool %}
    location / {
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade_{{ mail_host | regex_replace('[^A-Za-z0-9_]', '_') }};
        proxy_read_timeout 300;
        proxy_send_timeout 300;
    }
{% else %}
    location / {
        return 404;
    }
{% endif %}
}
